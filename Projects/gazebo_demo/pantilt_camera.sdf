<?xml version="1.0" ?>
<sdf version="1.10">
  <model name="pantilt">

    <static>false</static>

    <!-- Base -->
    <link name="base_link">
      <inertial>
        <mass>1.0</mass>
        <inertia>
          <ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz>
        </inertia>
      </inertial>
      <visual name="base_visual">
        <geometry>
          <box><size>0.1 0.1 0.05</size></box>
        </geometry>
      </visual>
    </link>

    <!-- Pan Link -->
    <link name="pan_link">
      <visual name="pan_visual">
        <geometry>
          <cylinder><radius>0.03</radius><length>0.05</length></cylinder>
        </geometry>
      </visual>
    </link>

    <joint name="pan_joint" type="revolute">
      <parent>base_link</parent>
      <child>pan_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14</lower>
          <upper>3.14</upper>
        </limit>
      </axis>
    </joint>

    <!-- Tilt Link -->
    <link name="tilt_link">
      <visual name="tilt_visual">
        <geometry>
          <box><size>0.05 0.05 0.05</size></box>
        </geometry>
      </visual>

      <!-- Camera -->
      <sensor name="camera" type="camera">
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>100</far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
      </sensor>
    </link>

    <joint name="tilt_joint" type="revolute">
      <parent>pan_link</parent>
      <child>tilt_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.57</lower>
          <upper>1.57</upper>
        </limit>
      </axis>
    </joint>

    <!-- Position Controllers -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>pan_joint</joint_name>
      <p_gain>10</p_gain>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>tilt_joint</joint_name>
      <p_gain>10</p_gain>
    </plugin>

  </model>
</sdf>
