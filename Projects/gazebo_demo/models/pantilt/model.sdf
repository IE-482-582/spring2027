<?xml version="1.0" ?>
<sdf version="1.10">
  <model name="pantilt">
    <pose>0 0 0.5 0 0 0</pose>
    <static>false</static>

    <!-- Base -->
    <link name="base_link">
      <inertial>
        <mass>1</mass>
        <inertia>
          <ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <box><size>0.1 0.1 0.05</size></box>
        </geometry>
      </visual>
    </link>

    <!-- Pan -->
    <link name="pan_link"/>
    <joint name="pan_joint" type="revolute">
      <parent>base_link</parent>
      <child>pan_link</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-3.14</lower>
          <upper>3.14</upper>
        </limit>
      </axis>
    </joint>

    <!-- Tilt -->
    <link name="tilt_link">
      <sensor name="camera" type="camera">
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
      </sensor>
    </link>

    <joint name="tilt_joint" type="revolute">
      <parent>pan_link</parent>
      <child>tilt_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-1.57</lower>
          <upper>1.57</upper>
        </limit>
      </axis>
    </joint>

    <!-- Position Controllers -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>pan_joint</joint_name>
      <p_gain>15</p_gain>
    </plugin>

    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>tilt_joint</joint_name>
      <p_gain>15</p_gain>
    </plugin>

  </model>
</sdf>
