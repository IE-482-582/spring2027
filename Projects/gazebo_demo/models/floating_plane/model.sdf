<?xml version="1.0" ?>
<sdf version="1.10">
  <model name="floating_plane">
    <pose>2 0 1 0 0 0</pose>
    <static>false</static>

    <link name="link">

      <visual name="visual">
        <geometry>
          <plane>
            <normal>1 0 0</normal>
            <size>2 2</size>
          </plane>
        </geometry>

		<material>
		  <ambient>1 1 1 1</ambient>
		  <diffuse>1 1 1 1</diffuse>
		  <specular>0 0 0 1</specular>

		  <pbr>
			<metal>
			  <albedo_map>model://floating_plane/materials/textures/image.png</albedo_map>
			  <metalness>0.0</metalness>
			  <roughness>1.0</roughness>
			</metal>
		  </pbr>
		</material>

      </visual>

    </link>
  </model>
</sdf>
